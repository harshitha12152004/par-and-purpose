# ============================================================
# Par & Purpose · Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to source control
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key   # Backend only — never expose to frontend

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...               # Use sk_test_... for development
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MONTHLY_PRICE_ID=price_...           # Create in Stripe Dashboard
STRIPE_YEARLY_PRICE_ID=price_...

# ── App URLs ─────────────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app    # No trailing slash
API_URL=https://your-api.vercel.app

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.yourdomain.com
SMTP_USER=hello@parpose.co
SMTP_PASS=your-smtp-password

# ── App ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
